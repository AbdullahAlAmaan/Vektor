{
  "name": "vektor",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["frontend", "backend/packages/*", "backend/services/*"],
  "scripts": {
    "build": "tsc -b",
    "dev:api": "node --env-file=.env --watch --require tsx/cjs backend/services/api/src/index.ts",
    "dev:ingestion": "node --env-file=.env --watch --require tsx/cjs backend/services/ingestion/src/index.ts",
    "dev:feature-worker": "node --env-file=.env --watch --require tsx/cjs backend/services/feature-worker/src/index.ts",
    "dev:recommendation": "node --env-file=.env --watch --require tsx/cjs backend/services/recommendation/src/index.ts",
    "dev:frontend": "cd frontend && next dev -p 3001",
    "db:migrate": "prisma migrate dev --schema=backend/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=backend/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=backend/prisma/schema.prisma",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "schema": "./backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
