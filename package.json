{
  "name": "vektor",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*", "services/*"],
  "scripts": {
    "build": "tsc -b",
    "dev:api": "tsx watch services/api/src/index.ts",
    "dev:ingestion": "tsx watch services/ingestion/src/index.ts",
    "dev:feature-worker": "tsx watch services/feature-worker/src/index.ts",
    "dev:recommendation": "tsx watch services/recommendation/src/index.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
